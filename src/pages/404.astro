---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="404 Tidak Ditemukan — Sarana Nusa Pakan"
  description="Halaman yang Anda cari tidak ditemukan. Kembali ke beranda Sarana Nusa Pakan untuk informasi pakan ternak dan produk nutrisi hewan."
>
  <main class="min-h-screen flex items-center justify-center bg-[#f5f4f0] text-[#043e2b] px-6">
    <section class="max-w-3xl rounded-3xl bg-white border border-[#043e2b]/10 p-10 shadow-[0_24px_80px_-40px_rgba(4,62,43,0.30)] text-center">
      <p class="text-sm uppercase tracking-[0.35em] text-[#15803d] font-bold">404</p>
      <h1 class="mt-6 text-4xl md:text-5xl font-black">Halaman tidak ditemukan</h1>
      <p class="mt-4 text-sm md:text-base text-[#232c28]/75 leading-relaxed">
        Maaf, halaman yang Anda akses tidak tersedia.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center justify-center rounded-full bg-[#043e2b] px-6 py-3 text-white font-bold tracking-widest uppercase hover:bg-[#15803d] transition-colors duration-300"
      >
        Kembali ke Beranda
      </a>
    </section>
  </main>
</Layout>
