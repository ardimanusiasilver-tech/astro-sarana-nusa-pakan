---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const allArticles = (await getCollection("artikel")).sort(
  (a: { data: { date: Date } }, b: { data: { date: Date } }) =>
    b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout
  title="Wawasan & Artikel Industri Pakan — Sarana Nusa Pakan"
  description="Kumpulan artikel dan wawasan seputar bahan pakan, nutrisi ternak, dan formulasi ransum dari Sarana Nusa Pakan."
>
  <Header />

  <main class="pt-24">
    <section class="px-8 md:px-24 py-20 md:py-28 max-w-7xl mx-auto space-y-14">
      <div class="space-y-3">
        <span
          class="text-xs font-bold tracking-[0.3em] uppercase text-[#15803d] block"
          >Pusat Edukasi</span
        >
        <h1
          class="text-4xl md:text-5xl font-black text-[#043e2b] tracking-tighter leading-none"
        >
          Wawasan &amp; Artikel <br /><span class="font-light text-[#232c28]"
            >Industri Pakan</span
          >
        </h1>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          allArticles.map((article: any) => (
            <a
              href={`/artikel/${article.slug}`}
              class="group flex flex-col border border-[#043e2b]/8 overflow-hidden hover:border-[#15803d]/30 transition-colors duration-500"
            >
              <div class="relative h-48 overflow-hidden bg-[#f5f4f0]">
                <img
                  src={article.data.image}
                  alt={article.data.imageAlt}
                  class="w-full h-full object-cover transition-transform duration-700 ease-spring group-hover:scale-105"
                  loading="lazy"
                />
                {article.data.featured && (
                  <span class="absolute top-4 left-4 bg-[#043e2b] text-[#faf9f5] text-[9px] font-bold tracking-widest uppercase px-3 py-1.5">
                    Unggulan
                  </span>
                )}
              </div>
              <div class="bg-[#f5f4f0] p-6 flex flex-col flex-1 justify-between gap-6">
                <div class="space-y-3">
                  <span class="text-[10px] font-mono text-[#15803d] uppercase tracking-wider block">
                    {article.data.date.toLocaleDateString("id-ID", {
                      day: "2-digit",
                      month: "short",
                      year: "numeric",
                    })}{" "}
                    — {article.data.category}
                  </span>
                  <h3 class="text-base font-bold text-[#043e2b] tracking-tight leading-snug group-hover:text-[#15803d] transition-colors duration-300">
                    {article.data.title}
                  </h3>
                  <p class="text-xs text-[#232c28]/65 font-light leading-relaxed">
                    {article.data.description}
                  </p>
                </div>
                <span class="inline-flex items-center gap-2 text-[10px] font-bold text-[#043e2b] tracking-widest uppercase group-hover:text-[#15803d] transition-colors duration-300">
                  Baca Selengkapnya
                  <svg
                    width="12"
                    height="12"
                    viewBox="0 0 14 14"
                    fill="none"
                    class="transition-transform duration-300 group-hover:translate-x-1"
                  >
                    <path
                      d="M1 7h12M8 2l5 5-5 5"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <Footer />
</Layout>
