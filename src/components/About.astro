---
const pillars = [
  {
    title: "Produk Terpercaya",
    desc: "Untuk terus menghadirkan produk berkualitas tinggi dan andal ke semua jalur distribusi lintas batas.",
  },
  {
    title: "Kemitraan Berkelanjutan",
    desc: "Membangun kemitraan bisnis jangka panjang yang saling menguntungkan dan berkelanjutan di berbagai pasar.",
  },
  {
    title: "Dukungan Industri",
    desc: "Mendukung secara mendasar parameter pertumbuhan industri pakan global yang sangat berkelanjutan.",
  },
  {
    title: "Integritas Profesional",
    desc: "Menyediakan model layanan komersial unggul yang dibalut dengan integritas dan profesionalisme tanpa kompromi.",
  },
];
---

<section id="about" class="py-32 bg-[#f5f4f0] border-y border-[#043e2b]/5 px-8 md:px-24">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16">
    <div class="lg:col-span-4 lg:sticky lg:top-32 self-start space-y-4">
      <span class="text-xs uppercase font-bold tracking-[0.3em] text-[#15803d] block">Filosofi Perusahaan</span>
      <h2 class="text-3xl md:text-4xl font-black text-[#043e2b] tracking-tighter leading-none">
        Visi & <br /><span class="font-light text-[#232c28]">Misi Perusahaan</span>
      </h2>
      <div class="w-20 h-[1px] bg-[#043e2b]/20 mt-4"></div>
    </div>

    <div class="lg:col-span-8 space-y-24 pr-0 lg:pr-12">
      <div class="space-y-4 max-w-xl">
        <span class="font-mono text-xs text-[#15803d] block">Tolok Ukur Tertinggi / Visi</span>
        <h3 class="text-2xl font-bold text-[#043e2b] tracking-tight">Posisi Kompetitif Global</h3>
        <p class="text-sm text-[#232c28]/70 leading-relaxed font-light">
          Menjadi perusahaan terpercaya dan kompetitif secara global dalam
          menyediakan bahan pakan presisi dan solusi nutrisi hewan premium
          untuk sektor pertanian modern.
        </p>
      </div>

      <div class="space-y-6 max-w-xl pt-4">
        <span class="font-mono text-xs text-[#15803d] block">Matriks Pelaksanaan / Kerangka Misi</span>
        <h3 class="text-2xl font-bold text-[#043e2b] tracking-tight">Empat Pilar Pelaksanaan</h3>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-2">
          {
            pillars.map((pillar) => (
              <div class="border-l border-[#043e2b]/10 pl-4 space-y-1">
                <h5 class="text-xs font-bold uppercase text-[#043e2b]">{pillar.title}</h5>
                <p class="text-xs text-[#232c28]/60 font-light">{pillar.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
