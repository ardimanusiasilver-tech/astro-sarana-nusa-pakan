---
import { getCollection } from "astro:content";

const allArticles = (await getCollection("artikel")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const featured = allArticles.find((a) => a.data.featured) ?? allArticles[0];
const rest = allArticles.filter((a) => a.slug !== featured?.slug).slice(0, 3);
---

<section id="education" class="py-32 px-8 md:px-24 bg-[#f5f4f0] border-y border-[#043e2b]/5">
  <div class="max-w-7xl mx-auto space-y-14">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
      <div class="space-y-3">
        <span class="text-xs font-bold tracking-[0.3em] uppercase text-[#15803d] block">Pusat Edukasi</span>
        <h2 class="text-4xl font-black text-[#043e2b] tracking-tighter leading-none">
          Wawasan &amp; Artikel <br /><span class="font-light text-[#232c28]">Industri Pakan</span>
        </h2>
      </div>
      <a
        href="/artikel"
        class="shrink-0 text-xs font-bold tracking-widest uppercase text-[#232c28] hover:text-[#15803d] transition-colors duration-300 pb-1"
      >
        Lihat Semua &rarr;
      </a>
    </div>

    {
      featured && (
        <a href={`/artikel/${featured.slug}`} class="group block">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 border border-[#043e2b]/8 overflow-hidden hover:border-[#15803d]/30 transition-colors duration-500">
            <div class="relative h-64 lg:h-[360px] overflow-hidden bg-[#f5f4f0]">
              <img
                src={featured.data.image}
                alt={featured.data.imageAlt}
                class="w-full h-full object-cover transition-transform duration-700 ease-spring group-hover:scale-105"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-r from-transparent to-[#043e2b]/10" />
            </div>
            <div class="bg-[#f5f4f0] p-8 md:p-12 flex flex-col justify-between gap-8">
              <div class="space-y-4">
                <div class="flex items-center gap-3">
                  <span class="bg-[#043e2b] text-[#faf9f5] text-[9px] font-bold tracking-widest uppercase px-3 py-1.5">
                    Unggulan
                  </span>
                  <span class="text-[10px] font-mono text-[#15803d] uppercase tracking-wider">
                    {featured.data.date.toLocaleDateString("id-ID", {
                      day: "2-digit",
                      month: "short",
                      year: "numeric",
                    })}{" "}
                    — {featured.data.category}
                  </span>
                </div>
                <h3 class="text-2xl md:text-3xl font-black text-[#043e2b] tracking-tight leading-tight group-hover:text-[#15803d] transition-colors duration-300">
                  {featured.data.title}
                </h3>
                <p class="text-sm text-[#232c28]/70 font-light leading-relaxed">{featured.data.description}</p>
              </div>
              <span class="inline-flex items-center gap-2 text-xs font-bold text-[#043e2b] tracking-widest uppercase group-hover:text-[#15803d] transition-colors duration-300">
                Baca Selengkapnya
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="transition-transform duration-300 group-hover:translate-x-1.5">
                  <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      )
    }

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        rest.map((article) => (
          <a
            href={`/artikel/${article.slug}`}
            class="group flex flex-col border border-[#043e2b]/8 overflow-hidden hover:border-[#15803d]/30 transition-colors duration-500"
          >
            <div class="relative h-48 overflow-hidden bg-[#f5f4f0]">
              <img
                src={article.data.image}
                alt={article.data.imageAlt}
                class="w-full h-full object-cover transition-transform duration-700 ease-spring group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="bg-[#f5f4f0] p-6 flex flex-col flex-1 justify-between gap-6">
              <div class="space-y-3">
                <span class="text-[10px] font-mono text-[#15803d] uppercase tracking-wider block">
                  {article.data.date.toLocaleDateString("id-ID", {
                    day: "2-digit",
                    month: "short",
                    year: "numeric",
                  })}{" "}
                  — {article.data.category}
                </span>
                <h3 class="text-base font-bold text-[#043e2b] tracking-tight leading-snug group-hover:text-[#15803d] transition-colors duration-300">
                  {article.data.title}
                </h3>
                <p class="text-xs text-[#232c28]/65 font-light leading-relaxed">{article.data.description}</p>
              </div>
              <span class="inline-flex items-center gap-2 text-[10px] font-bold text-[#043e2b] tracking-widest uppercase group-hover:text-[#15803d] transition-colors duration-300">
                Baca Selengkapnya
                <svg width="12" height="12" viewBox="0 0 14 14" fill="none" class="transition-transform duration-300 group-hover:translate-x-1">
                  <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
