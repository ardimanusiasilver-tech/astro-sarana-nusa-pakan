---
const products = [
  {
    title: "Canola Pro 38 (A)",
    index: 0,
    angle: 0,
    image: "/produk/Canola a.jpeg",
    spec: "Pro: 42 | Moist: 8.98 | Fat: 2.62 | Ash: 13.39",
  },
  {
    title: "Canola Pro 42 (B)",
    index: 1,
    angle: 30,
    image: "/produk/Canola b.jpeg",
    spec: "Pro: 38 | Moist: 7.79 | Fat: 2.29 | Ash: 15.24",
  },
];
---

<main
  class="relative min-h-screen pt-24 flex items-center overflow-hidden bg-[#faf9f5]"
>
  <!-- Dark split panel (desktop only) — bikin kontras kanan/kiri -->
  <div
    class="hidden lg:block absolute inset-y-0 right-0 w-[52%] bg-gradient-to-br from-[#043e2b] to-[#02241a]"
    style="clip-path: polygon(20% 0, 100% 0, 100% 100%, 0% 100%);"
  >
    <div
      class="absolute top-10 right-10 w-[520px] h-[520px] rounded-full bg-[#15803d]/35 blur-[130px] pointer-events-none animate-pulse"
      style="animation-duration: 9s"
    >
    </div>
    <div
      class="absolute bottom-0 left-10 w-[420px] h-[420px] rounded-full bg-[#15803d]/20 blur-[130px] pointer-events-none animate-pulse"
      style="animation-duration: 12s"
    >
    </div>
  </div>

  <!-- Ambient gradient (mobile/tablet only, sebelum split kepakai) -->
  <div
    class="lg:hidden absolute -top-40 -left-20 w-[600px] h-[600px] rounded-full bg-gradient-to-br from-[#15803d]/25 to-[#043e2b]/10 blur-[120px] pointer-events-none mix-blend-multiply animate-pulse"
    style="animation-duration: 8s"
  >
  </div>
  <div
    class="lg:hidden absolute top-1/4 -right-40 w-[800px] h-[800px] rounded-full bg-gradient-to-bl from-[#043e2b]/20 to-[#15803d]/10 blur-[140px] pointer-events-none mix-blend-multiply animate-pulse"
    style="animation-duration: 12s"
  >
  </div>
  <div
    class="lg:hidden absolute -bottom-40 left-1/3 w-[600px] h-[600px] rounded-full bg-gradient-to-tr from-[#15803d]/25 to-[#043e2b]/5 blur-[120px] pointer-events-none mix-blend-multiply animate-pulse"
    style="animation-duration: 10s"
  >
  </div>

  <div
    class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10 px-8 md:px-24"
  >
    <!-- LEFT: Text (sisi terang) -->
    <div class="lg:col-span-5 z-10 space-y-8 py-12">
      <div class="space-y-3">
        <span
          class="text-xs font-bold tracking-[0.3em] uppercase text-[#15803d] block"
          >Mitra Tepercaya Anda</span
        >
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-[#043e2b] tracking-tight leading-[0.95]"
        >
          Bahan Pakan. <br /><span class="font-light text-[#232c28]"
            >Solusi Nutrisi</span
          ><br />Hewan.
        </h1>
      </div>

      <p class="text-sm text-[#232c28]/70 leading-relaxed font-light max-w-md">
        PT Sarana Nusa Pakan adalah perusahaan yang bergerak dalam perdagangan
        serta distribusi bahan pakan berkualitas tinggi. Kami fokus untuk
        memenuhi kebutuhan pelanggan korporat lewat pasokan volume konsisten dan
        pelacakan mutu yang terjamin.
      </p>

      <div class="pt-4 flex items-center gap-6">
        <a
          href="#products"
          class="magnetic-btn inline-block px-8 py-4 bg-[#043e2b] text-[#faf9f5] text-xs font-bold tracking-widest uppercase transition-transform duration-700 ease-spring"
        >
          Produk Kami
        </a>
        <a
          href="#about"
          class="text-xs font-bold tracking-widest uppercase text-[#232c28] hover:text-[#15803d] transition-colors duration-300"
        >
          Baca Direktif &rarr;
        </a>
      </div>
    </div>

    <!-- RIGHT: Rotary Wheel (Desktop, di atas panel gelap) + Card Scroll (Mobile) -->
    <div
      class="lg:col-span-7 relative h-auto lg:h-[700px] w-full flex items-center justify-center lg:justify-end overflow-visible"
    >
      <div
        class="hidden lg:flex absolute right-[-280px] w-[750px] h-[750px] rounded-full border border-[#faf9f5]/10 pointer-events-none items-center justify-center"
      >
        <div
          class="w-[520px] h-[520px] rounded-full border border-[#faf9f5]/10 border-dashed"
        >
        </div>
      </div>

      <div
        class="hidden lg:block absolute right-[-280px] w-[750px] h-[750px] pointer-events-none z-10"
      >
        <div class="absolute inset-0 flex items-center justify-center">
          <div
            class="relative w-[260px] h-[260px] rounded-full overflow-hidden"
          >
            {
              products.map((p) => (
                <img
                  id={`wheel-img-${p.index}`}
                  src={p.image}
                  alt={p.title}
                  class="wheel-hero-img absolute inset-0 w-full h-full object-cover transition-opacity duration-600 ease-in-out"
                  style={{ opacity: p.index === 0 ? 1 : 0 }}
                />
              ))
            }
            <div
              class="absolute inset-0 rounded-full shadow-[inset_0_0_32px_rgba(0,0,0,0.45)]"
            >
            </div>
            <div
              class="absolute inset-0 rounded-full border-2 border-[#4ade80]/50"
            >
            </div>
          </div>
        </div>
      </div>

      <div
        id="rotary-wheel"
        class="hidden lg:flex absolute right-[-280px] w-[750px] h-[750px] items-center justify-center transition-transform duration-700 ease-spring"
        style="--current-angle: 0deg"
        data-products={JSON.stringify(products.map((p) => p.title))}
      >
        {
          products.map((p) => (
            <div
              class:list={[
                "wheel-item absolute text-right cursor-pointer select-none",
                p.index === 0
                  ? "text-[#faf9f5] font-black"
                  : "text-[#faf9f5]/40 font-light",
              ]}
              data-index={p.index}
              data-angle={p.angle}
              style={`--item-angle: ${p.angle}deg`}
            >
              <span class="text-xs tracking-wider font-mono opacity-50 mr-2">
                {String(p.index + 1).padStart(2, "0")}
              </span>
              <span class="text-sm md:text-base tracking-tight">{p.title}</span>
            </div>
          ))
        }
      </div>

      <!-- Mobile Cards -->
      <div class="block lg:hidden w-full pt-4 pb-8">
        <div class="flex items-center space-x-3 mb-6">
          <span class="w-8 h-[1px] bg-[#15803d]"></span>
          <span
            class="text-[10px] tracking-[0.3em] uppercase text-[#15803d] font-bold"
            >Sovereign Feed Matrix</span
          >
        </div>
        <div
          class="flex overflow-x-auto gap-5 snap-x snap-mandatory scrollbar-none pb-4 -mx-8 px-8"
        >
          {
            products.map((p) => (
              <div class="snap-center shrink-0 w-[295px] bg-[#f5f4f0] p-7 border border-[#043e2b]/10 flex flex-col justify-between min-h-[230px] shadow-sm transition-all active:scale-[0.98]">
                <span class="font-mono text-[10px] text-[#15803d] block">
                  {String(p.index + 1).padStart(2, "0")} / CORE COMMODITY
                </span>
                <div class="space-y-2 mt-4 flex-1">
                  <h4 class="text-lg font-black text-[#043e2b] uppercase tracking-tight">
                    {p.title}
                  </h4>
                  <p class="text-xs text-[#232c28]/70 font-light leading-relaxed">
                    {p.spec}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</main>

<script>
  // ── Rotary wheel interactivity (khusus Hero) ──
  function initRotaryWheel() {
    const wheel = document.getElementById("rotary-wheel");
    const wheelItems = document.querySelectorAll<HTMLElement>(".wheel-item");

    if (!wheel || !wheelItems.length) return;

    wheelItems.forEach((item) => {
      item.addEventListener("click", () => {
        const angle = parseInt(item.getAttribute("data-angle") ?? "0", 10);
        const index = parseInt(item.getAttribute("data-index") ?? "0", 10);
        const finalAngle = -angle;

        document.querySelectorAll<HTMLElement>(".wheel-item").forEach((el) => {
          el.style.setProperty("--current-angle", `${finalAngle}deg`);
        });
        wheel.style.setProperty("--current-angle", `${finalAngle}deg`);

        wheelItems.forEach((el) => {
          el.classList.remove("text-[#faf9f5]", "font-black");
          el.classList.add("text-[#faf9f5]/40", "font-light");
        });
        item.classList.remove("text-[#faf9f5]/40", "font-light");
        item.classList.add("text-[#faf9f5]", "font-black");

        document
          .querySelectorAll<HTMLElement>(".wheel-hero-img")
          .forEach((img, i) => {
            img.style.opacity = i === index ? "1" : "0";
          });
      });
    });
  }

  initRotaryWheel();
</script>
